APP_NAME=AI Character Platform Backend
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
API_V1_PREFIX=/api/v1

DATABASE_URL=sqlite:///./data/ai_character.db
DATABASE_ECHO=false

DEFAULT_LLM_PROVIDER=mock
DEFAULT_LLM_MODEL=mock-chat-v1

AI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions
AI_API_KEY=your-api-key
AI_MODEL=qwen3.5-27b
AI_TIMEOUT=600
AI_ENABLE_THINKING=false
# AI_THINKING_BUDGET=1024

LOG_LEVEL=INFO
CORS_ALLOW_ORIGINS=*
